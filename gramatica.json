{
  "terminal": ["+", "*", "(", ")", "id", "$"],
  "nonterminal": ["E", "X", "T", "Y", "F"],
  "grammar": {
    "E": ["TX"],
    "X": ["+TX", "null"],
    "T": ["FY"],
    "Y": ["*FY", "null"],
    "F": ["(E)", "id"]
  },
  "first": {
    "E": ["(", "id"],
    "X": ["+", "null"],
    "T": ["(", "id"],
    "Y": ["*", "null"],
    "F": ["(", "id"]
  },
  "follow": {
    "E": [")", "$"],
    "X": [")", "$"],
    "T": ["+", ")", "$"],
    "Y": ["+", ")", "$"],
    "F": ["*", "+", ")", "$"]
  },
  "tableM": {
    "E": {
      "id": "TX",
      "(": "TX"
    },
    "X": {
      "+": "+TX",
      ")": "null",
      "$": "null"
    },
    "T": {
      "id": "FY",
      "(": "FY"
    },
    "Y": {
      "+": "null",
      "*": "*FY",
      ")": "null",
      "$": "null"
    },
    "F": {
      "id": "id",
      "(": "(E)"
    }
  }
}